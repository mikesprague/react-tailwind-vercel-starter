{
  "name": "react-tailwindcss-vercel-starter",
  "version": "0.1.0",
  "description": "Template for a barebones Vercel hosted React/Tailwind CSS PWA with an API endpoint powered by a serverless function",
  "private": true,
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.12.1",
  "type": "module",
  "scripts": {
    "build": "npx vite build",
    "dev": "npx vite serve --port $PORT",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=development npx vercel dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "repository": {
    "url": "https://github.com/mikesprague/react-tailwindcss-vercel-starter"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "homepage": "",
  "license": "MIT",
  "dependencies": {
    "@tippyjs/react": "4.2.6",
    "cross-env": "10.1.0",
    "daisyui": "5.5.20",
    "dayjs": "1.11.21",
    "dotenv": "17.4.2",
    "prop-types": "15.8.1",
    "react": "19.2.7",
    "react-dom": "19.2.6",
    "react-icons": "5.6.0",
    "swr": "2.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@vitejs/plugin-react": "6.0.2",
    "cz-git": "1.13.1",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.0",
    "vercel": "54.7.1",
    "vite": "8.0.14",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "ajv": "^8.18.0",
    "glob": "^13.0.6",
    "minimatch": "^10.2.5",
    "path-to-regexp": "^8.4.2",
    "serialize-javascript": "^7.0.5",
    "smol-toml": "1.6.1",
    "srvx": "0.11.15",
    "tar": "^7.5.13",
    "undici": "^8.1.0",
    "vite": "8.0.14",
    "yauzl": "^3.3.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "24.14.1",
    "npm": "11.12.1"
  }
}
