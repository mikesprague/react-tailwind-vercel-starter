{
  "name": "react-tailwindcss-vercel-starter",
  "version": "0.1.0",
  "description": "Template for a barebones Vercel hosted React/Tailwind CSS PWA with an API endpoint powered by a serverless function",
  "private": true,
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.16.0",
  "type": "module",
  "scripts": {
    "build": "npx tsc -b && npx vite build",
    "clean": "rm -rf ./dist",
    "dev:vite": "npx vite serve --port $PORT",
    "format": "npx oxfmt src",
    "format:check": "npx oxfmt --check src",
    "lint": "npx oxlint .",
    "prebuild": "npm run clean",
    "preview": "npx vite preview",
    "start": "vercel dev --listen 3001",
    "test": "npm run format:check && npm run lint && npm run typecheck",
    "typecheck": "npx tsc --noEmit"
  },
  "keywords": [],
  "repository": {
    "url": "https://github.com/mikesprague/react-tailwindcss-vercel-starter"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "homepage": "",
  "license": "MIT",
  "dependencies": {
    "daisyui": "5.5.23",
    "dayjs": "1.11.21",
    "dotenv": "17.4.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.6.0",
    "swr": "2.4.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "cssnano": "8.0.1",
    "cz-git": "1.13.1",
    "globals": "17.6.0",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vercel": "54.10.2",
    "vite": "8.0.16",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "ajv": "^8.20.0",
    "glob": "^13.0.6",
    "minimatch": "^10.2.5",
    "path-to-regexp": "^8.4.2",
    "serialize-javascript": "^7.0.5",
    "smol-toml": "^1.6.1",
    "srvx": "^0.11.16",
    "tar": "^7.5.16",
    "undici": "^8.4.0",
    "yauzl": "^3.4.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "24.16.0",
    "npm": "11.16.0"
  }
}
